@startuml SDE_Spark_Brownfield_Architecture
!theme cerulean
title SDE Spark Brownfield Architecture\nSynopsis Data Engine - Flink → Spark Migration (v1.0)
skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 11
skinparam rectangleBorderColor #333333
skinparam rectangleBorderThickness 2
skinparam arrowThickness 2
skinparam shadowing false
skinparam legendBackgroundColor #F5F5F5

' ============================================
' KAFKA TOPICS (External)
' ============================================
queue "Kafka\ndata_topic" as KD #1a73e8
queue "Kafka\nrequest_topic" as KR #1a73e8
queue "Kafka\nestimation_topic" as KO #1a73e8

' ============================================
' LAYER 1: INGESTION
' ============================================
rectangle "**LAYER 1: Ingestion & Parsing**" as L1 #E8F5E9 {
    rectangle "KafkaIngestionLayer\n---\nreadStream.format(\"kafka\")\nCAST(value AS STRING)" as KIL #C8E6C9
    rectangle "Deserialize\n→ Datapoint" as PDP #C8E6C9
    rectangle "Deserialize\n→ Request\n(validate synopsisID)" as PRQ #C8E6C9
}

' ============================================
' LAYER 2: ROUTING
' ============================================
rectangle "**LAYER 2: Routing & Registration**" as L2 #FFF3E0 {
    rectangle "**DataRouter**\n---\nflatMapGroupsWithState\n---\nRoute Datapoint to all\nregistered synopses\n---\nState: DataRoutingState" as DR #FFE0B2
    rectangle "**RequestRouter**\n---\nflatMapGroupsWithState\n---\n1 Request → N copies\n(key_0 ... key_N-1)\n---\nState: RegistrationState" as RR #FFE0B2
}

' ============================================
' UNION
' ============================================
rectangle "Union: Dataset<InputEvent>\n(discriminated: DATA | REQUEST)" as UNION #E0E0E0

' ============================================
' LAYER 3: CORE PROCESSING
' ============================================
rectangle "**LAYER 3: Core Synopsis Processing** ⭐" as L3 #FFF8E1 {
    rectangle "**SynopsisProcessor**\n---\nflatMapGroupsWithState\nGroupState<SynopsisProcessorState>\n===\nDataInput → iterate synopses, add()\nRequest(ADD) → Factory.create()\nRequest(ESTIMATE) → estimate()\nRequest(DELETE) → remove\n===\nBackend: RocksDB + HDFS" as SP #FF6F00;text:white
    rectangle "SynopsisFactory\n---\n1 → CountMin\n2 → Bloomfilter\n3 → AMSsynopsis\n7 → HyperLogLog" as SF #FFCC80
}

' ============================================
' LAYER 4: PATH SPLITTING
' ============================================
rectangle "**LAYER 4: Path Splitting**" as L4 #F3E5F5 {
    rectangle "PathSplitter\nfilter(noOfP)" as PS #E1BEE7
}

' ============================================
' LAYER 5: AGGREGATION
' ============================================
rectangle "**LAYER 5: Aggregation**" as L5 #FAFAFA {
    rectangle "**GREEN PATH**\nnoOfP == 1\n---\nDirect passthrough\nNo merging" as GREEN #C8E6C9
    rectangle "**PURPLE PATH**\nnoOfP > 1\n---\nReduceAggregator\nflatMapGroupsWithState\ngroupBy(uid)\n---\nCountMin → Sum\nBloom → OR\nAMS → Sum\nHLL → Sum/Merge" as PURPLE #E1BEE7
    rectangle "**YELLOW PATH**\ngeo-dispersed\n---\n(DEFERRED v1.0)\nCross-region merge" as YELLOW #FFF9C4
}

' ============================================
' LAYER 6: OUTPUT
' ============================================
rectangle "**LAYER 6: Output**" as L6 #BBDEFB {
    rectangle "KafkaOutputLayer\n---\nwriteStream.format(\"kafka\")\nEstimation → JSON\nTrigger: ProcessingTime(1s)" as KOL #90CAF9
}

' ============================================
' INFRASTRUCTURE
' ============================================
database "RocksDB\nLocal SSD\nState Backend" as ROCKS #ECEFF1
database "HDFS / S3\nCheckpoint\nStorage" as HDFS #ECEFF1

' ============================================
' MODULE STRUCTURE
' ============================================
rectangle "**Maven Multi-Module Structure**" as MOD #FCE4EC {
    rectangle "sde-common\nMessages, Synopsis\nReduceFunctions" as MC #FFCDD2
    rectangle "sde-flink\n(existing, untouched)" as MF #FFCDD2
    rectangle "sde-spark\n(new implementation)" as MS #FFCDD2
}

' ============================================
' CONNECTIONS
' ============================================
' Layer 1
KD -down-> KIL : JSON
KR -down-> KIL : JSON
KIL -down-> PDP
KIL -down-> PRQ

' Layer 2
PDP -down-> DR
PRQ -down-> RR
PRQ .down.> DR : registration\nupdates

' Union
DR -down-> UNION : Tagged DATA
RR -down-> UNION : Tagged REQUEST

' Layer 3
UNION -down-> SP : groupByKey\n(partitionKey)
SF .right.> SP : creates

' Layer 4
SP -down-> PS : Iterator<Estimation>

' Layer 5
PS -down-> GREEN : noOfP == 1
PS -down-> PURPLE : noOfP > 1
PS .down.> YELLOW : future

' Layer 6
GREEN -down-> KOL
PURPLE -down-> KOL
KOL -down-> KO : JSON

' Infrastructure
SP ..> ROCKS : state\nread/write
PURPLE ..> ROCKS : state
ROCKS ..> HDFS : checkpoint

' Modules
MC .right.> MF : dependency
MC .right.> MS : dependency

' ============================================
' LEGEND
' ============================================
legend right
  |= Color |= Meaning |
  | <#1a73e8> | Kafka Topics (External) |
  | <#C8E6C9> | Layer 1: Ingestion |
  | <#FFE0B2> | Layer 2: Routing (Stateful) |
  | <#FF6F00> | Layer 3: Core Processing (Stateful) |
  | <#E1BEE7> | Layer 4-5: Split & Aggregate |
  | <#90CAF9> | Layer 6: Output |
  | <#ECEFF1> | Infrastructure |
  ---
  **SDE Spark Edition v1.0**
  4 Algorithms: CountMin, Bloom, AMS, HLL
  Paths: GREEN + PURPLE (YELLOW deferred)
  State: RocksDB + HDFS Checkpoint
endlegend

@enduml
